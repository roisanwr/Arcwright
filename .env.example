# ============================================================
#  Arcwright — Environment Variables
#  Copy ke .env dan isi sesuai kebutuhan
# ============================================================


# ────────────────────────────────────────────────────────────
#  GLOBAL DEFAULT
#  Semua agent pakai ini kalau tidak di-override per-agent
# ────────────────────────────────────────────────────────────

# Provider default: openai | anthropic | openrouter | ollama | custom
DEFAULT_PROVIDER=openai

# Model default
DEFAULT_MODEL=gpt-4o-mini


# ────────────────────────────────────────────────────────────
#  API KEYS — Global
#  Dipakai semua agent kecuali agent yang punya key sendiri
# ────────────────────────────────────────────────────────────

OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...


# ────────────────────────────────────────────────────────────
#  CUSTOM ENDPOINTS — Global
# ────────────────────────────────────────────────────────────

# Ollama (local AI) — jalankan model lokal
# OLLAMA_BASE_URL=http://localhost:11434

# Custom OpenAI-compatible endpoint (Groq, Together, LM Studio, vLLM, dll)
# CUSTOM_API_BASE_URL=https://api.groq.com/openai/v1


# ────────────────────────────────────────────────────────────
#  PER-AGENT CONFIGURATION
#
#  Tiap agent punya 4 setting opsional:
#    {PREFIX}_PROVIDER  = provider untuk agent ini
#    {PREFIX}_MODEL     = model untuk agent ini
#    {PREFIX}_TEMP      = temperature (0.0 - 1.0)
#    {PREFIX}_API_KEY   = API key khusus agent ini (override global)
#    {PREFIX}_BASE_URL  = endpoint khusus agent ini (override global)
#
#  Kalau tidak diisi → fallback ke DEFAULT_PROVIDER / DEFAULT_MODEL / global key
# ────────────────────────────────────────────────────────────

# ── Story Director — otak pipeline (routing, decision making) ──────────────
# DIRECTOR_PROVIDER=openai
# DIRECTOR_MODEL=gpt-4o
# DIRECTOR_TEMP=0.2
# DIRECTOR_API_KEY=sk-...
# DIRECTOR_BASE_URL=https://api.openai.com/v1

# ── Story Miner — interviewer empatik ──────────────────────────────────────
# MINER_PROVIDER=openai
# MINER_MODEL=gpt-4o-mini
# MINER_TEMP=0.7
# MINER_API_KEY=sk-...
# MINER_BASE_URL=

# ── RAG Librarian — factual retrieval ──────────────────────────────────────
# RAG_PROVIDER=openai
# RAG_MODEL=gpt-4o-mini
# RAG_TEMP=0.1
# RAG_API_KEY=sk-...
# RAG_BASE_URL=

# ── Web Researcher — trend research ────────────────────────────────────────
# WEB_PROVIDER=openai
# WEB_MODEL=gpt-4o-mini
# WEB_TEMP=0.2
# WEB_API_KEY=sk-...
# WEB_BASE_URL=

# ── Deep Dive — analisis 5 perspektif ──────────────────────────────────────
# DEEPDIVE_PROVIDER=openai
# DEEPDIVE_MODEL=gpt-4o-mini
# DEEPDIVE_TEMP=0.4
# DEEPDIVE_API_KEY=sk-...
# DEEPDIVE_BASE_URL=

# ── Validator — scoring presisi ────────────────────────────────────────────
# VALIDATOR_PROVIDER=openai
# VALIDATOR_MODEL=gpt-4o-mini
# VALIDATOR_TEMP=0.2
# VALIDATOR_API_KEY=sk-...
# VALIDATOR_BASE_URL=

# ── Outline Writer — synthesis kreatif ─────────────────────────────────────
# OUTLINE_PROVIDER=openai
# OUTLINE_MODEL=gpt-4o-mini
# OUTLINE_TEMP=0.7
# OUTLINE_API_KEY=sk-...
# OUTLINE_BASE_URL=

# ── Script Writer — output akhir ────────────────────────────────────────────
# SCRIPT_PROVIDER=openai
# SCRIPT_MODEL=gpt-4o-mini
# SCRIPT_TEMP=0.8
# SCRIPT_API_KEY=sk-...
# SCRIPT_BASE_URL=


# ────────────────────────────────────────────────────────────
#  WEB SEARCH
# ────────────────────────────────────────────────────────────

# Tavily — free 1000 req/bulan — https://app.tavily.com
# Kalau kosong, Web Researcher di-skip otomatis
TAVILY_API_KEY=tvly-...


# ────────────────────────────────────────────────────────────
#  LANGSMITH OBSERVABILITY (optional)
#  https://smith.langchain.com
# ────────────────────────────────────────────────────────────

LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT=arcwright


# ────────────────────────────────────────────────────────────
#  QDRANT VECTOR DATABASE (replaces ChromaDB)
#  Docker container — jalankan: docker compose up -d
# ────────────────────────────────────────────────────────────

# Qdrant REST API endpoint
QDRANT_URL=http://localhost:6333

# Nama collection untuk storytelling knowledge base
QDRANT_COLLECTION=storytelling_books
